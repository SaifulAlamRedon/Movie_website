# Runtime
NODE_ENV=development
PORT=3001

# Frontend
# Comma-separated origins are supported when the frontend runs on a different host.
FRONTEND_URL=http://localhost:3000

# Database
# Use either DATABASE_URL or the individual DB_* variables below.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cinemaflow
DB_USERNAME=postgres
DB_PASSWORD=6968

# Database behavior
DB_RUN_MIGRATIONS=false
DB_SYNCHRONIZE=true

# Admin auth
ADMIN_SIGNUP_KEY=saiful
ADMIN_TOKEN_SECRET=saiful
